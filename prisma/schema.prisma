generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id           Int     @id @default(autoincrement())
  year         String
  question     String
  options      Json
  correctIndex Int
  explanation  String?
  
  @@index([year])
}
