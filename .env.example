# SL Accounting MCQ environment variables
# Copy to .env.local for local development. Set production values in Portainer.

NEXT_PUBLIC_BASE_URL="https://mcq.clossyan.com"
APP_URL="https://mcq.clossyan.com"

# Database - used locally only (production uses DB_PASSWORD + entrypoint.sh)
DATABASE_URL="postgresql://mcquser:mcqpassword@localhost:5432/mcqdb?schema=public"

# Production-only values for docker-compose.yml.
POSTGRES_PASSWORD="replace-with-a-long-url-safe-password"
CF_TUNNEL_TOKEN="replace-with-a-new-cloudflare-tunnel-token"
